# MySQL read replica — analytical/training reads only (mirrors api/.env's
# DB_READ_HOST/PORT split). Defaults to the primary when no replica exists.
DB_READ_HOST=127.0.0.1
DB_READ_PORT=3306
DB_DATABASE=attendance_db
DB_USERNAME=root
DB_PASSWORD=

# Must match api/.env's DETENTION_THRESHOLD so training labels agree with
# how Laravel computes detention.
DETENTION_THRESHOLD=75

MODEL_DIR=trained_models
MODEL_VERSION=detention_v1

# Sentry — leave empty to disable error reporting
# Get your DSN from https://sentry.io → Project → SDK Setup
SENTRY_DSN=
ENVIRONMENT=production
