DB_HOST=localhost
DB_PORT=3306
DB_NAME=attendance_db
DB_USER=root
DB_PASS=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_SECURE=tls

# SMTP Rotation — Add multiple Gmail accounts as JSON to rotate when limit is hit
# Gmail allows 500 emails/day per account. We rotate at 450 (SMTP_ROTATION_LIMIT).
# Leave SMTP_ACCOUNTS empty to use the single account above.
# SMTP_ACCOUNTS=[{"host":"smtp.gmail.com","port":587,"username":"acc1@gmail.com","password":"app-pass1","secure":"tls"},{"host":"smtp.gmail.com","port":587,"username":"acc2@gmail.com","password":"app-pass2","secure":"tls"}]
SMTP_ROTATION_LIMIT=450

APP_NAME="College Attendance Portal"
TIMEZONE=Asia/Kolkata
COLLEGE_NAME="My College"

# Detention threshold (%) — students below this are marked detained
DETENTION_THRESHOLD=75
