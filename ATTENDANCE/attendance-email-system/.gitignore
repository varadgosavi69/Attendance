# Dependencies
/vendor/
/api/vendor/
/node_modules/
/frontend/node_modules/
/ml-service/.venv/

# Environment (keep .env.example tracked)
.env
.env.*
!.env.example
!*/.env.example

# Logs
/logs/*.log
/storage/logs/*
/api/storage/logs/*
!/api/storage/logs/.gitignore
server_log.txt

# Python
/ml-service/__pycache__/
**/__pycache__/
*.pyc

# ML model artifacts (regenerated by training, not committed)
/ml-service/trained_models/*.joblib

# Docker volume mounts / local data
/infrastructure/docker/**/data/

# Stray SQLite file created by some test runs (tests use :memory:)
/api/attendance_db

# OS Files
.DS_Store
Thumbs.db
